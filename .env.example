# Vertex AI proxy env (api/tutor.js). Copy to .env and fill in real values.
# .env is gitignored; this template is safe to commit.

GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# Optional model override. Default in code is gemini-2.5-pro.
# gemini-2.5-flash = ~25x cheaper, lower latency — good for classroom demo.
GEMINI_MODEL=gemini-2.5-pro

# Service-account JSON as a SINGLE LINE (compacted). Role needed: Vertex AI User.
# Generate: gcloud iam service-accounts keys create key.json --iam-account=SA_EMAIL
# Never commit the raw key file.
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# --- Google Cloud TTS voice-out (api/tts.js) — OPTIONAL online enhancement ---
# Reuses GCP_SA_KEY above. Needs Cloud TTS API enabled (texttospeech.googleapis.com).
# Unset GCP_SA_KEY = client falls back to on-device speechSynthesis (offline floor).
# Voices: fil-PH-Wavenet-A/B/C/D (natural) or fil-PH-Standard-A/B/C/D (cheaper).
TTS_VOICE=fil-PH-Wavenet-A
TTS_LANG=fil-PH

# --- Content generation (scripts/generate-content.js) — build-time only ---
# Reuses the Vertex creds above; only the npm run gen:content pipeline uses it.
GEN_MODEL=gemini-2.5-flash
