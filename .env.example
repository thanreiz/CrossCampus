# Vertex AI proxy env (api/tutor.js). Copy to .env and fill in real values.
# .env is gitignored; this template is safe to commit.

GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# Optional model override. Default in code is gemini-2.5-pro.
# gemini-2.5-flash = ~25x cheaper, lower latency — good for classroom demo.
GEMINI_MODEL=gemini-2.5-pro

# Service-account JSON as a SINGLE LINE (compacted). Role needed: Vertex AI User.
# Generate: gcloud iam service-accounts keys create key.json --iam-account=SA_EMAIL
# Never commit the raw key file.
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# --- ElevenLabs voice-out (api/tts.js) — OPTIONAL online enhancement ---
# Unset = client falls back to on-device speechSynthesis (offline floor).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Featherless content generation (scripts/generate-content.js) — build-time only ---
# Never used by the client/runtime; only the npm run gen:content pipeline.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
